    { accent = Color3.fromRGB(220, 220, 220), hi = Color3.fromRGB(255, 255, 255) }, -- White
}

local function readPrefsFromFile()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then return nil end
    if not isfile("VantaConfig.json") then return nil end
    local okRead, raw = pcall(readfile, "VantaConfig.json")
    if not okRead or type(raw) ~= "string" or raw == "" then return nil end
    local okDec, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
    if okDec and type(decoded) == "table" then
        return decoded
    end
    return nil
end

local function resolveLoaderPrefs()
    if type(shared) == "table" and type(shared.VantaPrefs) == "table" then
        return shared.VantaPrefs
    end
    if type(g) == "table" and type(g.VantaPrefs) == "table" then
        return g.VantaPrefs
    end
    if type(_G) == "table" and type(_G.VantaPrefs) == "table" then
        return _G.VantaPrefs
    end
    return readPrefsFromFile() or {}
end

local loaderPrefs = resolveLoaderPrefs()
local themeIndex = tonumber(loaderPrefs.theme) or 1
