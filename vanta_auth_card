    { accent = Color3.fromRGB(160, 100, 255), hi = Color3.fromRGB(180, 130, 255) }, -- Purple
    { accent = Color3.fromRGB(52, 199, 120),  hi = Color3.fromRGB(80, 220, 150)  }, -- Green
