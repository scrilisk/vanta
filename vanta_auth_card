    TweenService:Create(title, TweenInfo.new(0.18), { TextTransparency = 1 }):Play()
    TweenService:Create(sub, TweenInfo.new(0.18), { TextTransparency = 1 }):Play()
    TweenService:Create(dots, TweenInfo.new(0.18), { TextTransparency = 1 }):Play()
    TweenService:Create(icon, TweenInfo.new(0.18), { ImageTransparency = 1 }):Play()
    tweenOut:Play()
    pcall(function() tweenOut.Completed:Wait() end)

    if screen and screen.Parent then
        screen:Destroy()
    end
    state.authCardActive = false
end)
